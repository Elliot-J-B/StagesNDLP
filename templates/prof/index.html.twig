{% extends 'base.html.twig' %}

{% block title %}Prof index{% endblock %}

{% block body %}

<nav class="navbar fixed-top navbar-expand-lg bg-body-tertiary">
  <div class="container-fluid">
    <img src="/images/logo.jpeg" alt="Logo" width="35" height="35" {# Logo de l'entreprise#}
      class="d-inline-block align-text-top">
      <a class="navbar-brand"></a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup"
      aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav w-100">
        <a class="nav-link" href="/">Accueil</a> {# Redirige vers l'accueil #}
        <a class="nav-link" href="/dashboard">Dashboard</a> {# Redirige vers la section comment ça marche ? #}
        <a class="nav-link" href="/entreprise">Gestion Entreprises / Stages</a> {# Redirige vers la page de recherches d'entreprises#}
        <a class="nav-link active" aria-current="page" href="/prof">Gestion Roles</a>
      </div>
    </div>
  </div>
</nav>

<br>
<br>
<br>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Username</th>
                <th>Roles</th>
                <th>Password</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for prof in profs %}
            <tr>
                <td>{{ prof.id }}</td>
                <td>{{ prof.username }}</td>
                <td>{{ prof.roles ? prof.roles|json_encode : '' }}</td>
                <td>{{ prof.password }}</td>
                <td>
                    <a href="{{ path('app_prof_show', {'id': prof.id}) }}">show</a>
                    <a href="{{ path('app_prof_edit', {'id': prof.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_prof_new') }}">Create new</a>
{% endblock %}
