<!doctype html>
<html lang="fr">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>{% block title %}Welcome!{% endblock %}</title>

    {% block stylesheets %}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    {% endblock %}

    {% block javascripts %}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>

<body>
<div class="container">
    {% block body %}
        {% set error_message = app.session.get('_error_message') %}
{% if error_message %}
    <div class="card bg-secondary-subtle shadow-lg mx-auto text-center" style="max-width: 1200px; border-radius: 0.75rem; margin-top: 8rem;">
        <div class="card-body">
            <h4 class="card-title text-danger fw-bold">
                <i class="bi bi-exclamation-triangle-fill"></i> Accès refusé
            </h4>
            <p class="card-text text-danger">{{ error_message }}</p>
        </div>
    </div>
    {% do app.session.remove('_error_message') %}
{% endif %}
        <div id="content">
            {% block content %}{% endblock %}
        </div>
    {% endblock %}   
</div>
</body>
</body>

</html>