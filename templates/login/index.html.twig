{% extends 'base.html.twig' %}

{# ... #}

{% block body %}
    {% if error %}
        <div>{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    
    <p id="home"></p> {# Ancre pour le lien vers l'accueil #}
<nav class="navbar fixed-top navbar-expand-lg bg-body-tertiary">
  <div class="container-fluid">
    <img src="/images/logo.jpeg" alt="Logo" width="35" height="35" {# Logo de l'entreprise#}
      class="d-inline-block align-text-top">
    <a class="navbar-brand" href="/#">Décroche ton stage !<p class="fs-6 fw-light mb-0">Le bouche à oreille 2.0</p></a>
    {# Nom
    du site #}
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup"
      aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav w-100">
        <a class="nav-link" href="/#home">Accueil</a> {# Redirige vers l'accueil #}
        <a class="nav-link" href="/#tuto">Comment ça marche ?</a> {# Redirige vers la section comment ça marche ? #}
        <a class="nav-link" href="/page1">Se lancer</a> {# Redirige vers la page de recherches d'entreprises#}
        <a class="nav-link active" aria-current="page" href="/connecter">Se connecter</a>
      </div>
    </div>
  </div>
</nav>



<br>
<br>
<br>
<br>





<div class="card bg-secondary-subtle shadow-lg p-3 mb-5 bg-body-tertiary rounded-1.25"
  style="max-width: 80rem; border-radius: 0.75rem;">
  <div class="row g-0">
    
    <div class="col-md-8">
      <div class="card-body">
        <h5 class="card-title>">Se connecter</h5>   
<form action="{{ path('app_login') }}" method="post">
        <label for="username">Identifiant:</label>
        <input type="text" id="username" name="_username" value="{{ last_username }}" required>
<br>
        <label for="password">Mot de passe:</label>
        <input type="password" id="password" name="_password" required>

        {# If you want to control the URL the user is redirected to on success
        <input type="hidden" name="_target_path" value="/account"> #}
<br>


<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
    <button type="submit">login</button>
    </form>
    </div>
{% endblock %}