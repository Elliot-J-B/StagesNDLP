{% extends 'base.html.twig' %}

{% block title %}Entreprise{% endblock %}

{% block body %}
    <h1>Entreprise</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ entreprise.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ entreprise.nom }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ entreprise.email }}</td>
            </tr>
            <tr>
                <th>Image</th>
                <td><img src="{{ entreprise.image }}" alt="{{ entreprise.nom }}" class="img-fluid"></td>
            </tr>
            <tr>
                <th>Numero</th>
                <td>{{ entreprise.numero }}</td>
            </tr>
            <tr>
                <th>Descriptif</th>
                <td>{{ entreprise.descriptif }}</td>
            </tr>
            <tr>
                <th>Localisation</th>
                <td>{{ entreprise.localisation }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_entreprise_index') }}">back to list</a>

    <a href="{{ path('app_entreprise_edit', {'id': entreprise.id}) }}">edit</a>

    {{ include('entreprise/_delete_form.html.twig') }}
{% endblock %}
